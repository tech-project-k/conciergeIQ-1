# ConciergeIQ Configuration Settings
# Fill in your API keys below to enable live searches, weather, and real AI planning.
# If left blank, the app will gracefully run using high-quality local simulated fallbacks!

# 1. AI Model Key (OpenAI or compatible endpoint)
OPENAI_API_KEY=
OPENAI_API_BASE=https://api.openai.com/v1

# 2. Weather Updates (Get a free key from https://openweathermap.org/)
OPENWEATHER_API_KEY=

# 3. Google Maps and Places Search (Get a key from Google Cloud Console)
GOOGLE_MAPS_API_KEY=
