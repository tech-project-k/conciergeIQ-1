# =====================================================================
# Why it exists:
# Acts as a template for configuring the necessary API keys and environment
# settings without exposing sensitive credentials in the source code.
#
# What it does:
# Declares placeholders for Gemini LLM, Google Maps, OpenWeather, 
# and other external services.
#
# How it works:
# Standard key-value pairing read by python-dotenv at runtime.
#
# How it integrates:
# Users copy this file to `.env` and fill in their actual API keys.
# The `config/settings.py` module parses this `.env` file to configure services.
# =====================================================================

# FastAPI Application Config
PORT=8085
HOST=127.0.0.1
DEBUG=True

# Google Gemini LLM API Key (Crucial for all AI Agents)
GEMINI_API_KEY=YOUR_GEMINI_API_KEY_HERE

# Google Maps API Credentials (For Places & Directions search)
GOOGLE_MAPS_API_KEY=YOUR_GOOGLE_MAPS_API_KEY_HERE

# OpenWeather API (For weather forecast checks)
OPENWEATHER_API_KEY=YOUR_OPENWEATHER_API_KEY_HERE

# Ticketmaster API Key (For live local events search - Free Tier)
TICKETMASTER_API_KEY=YOUR_TICKETMASTER_API_KEY_HERE

# Foursquare Places API Key (Alternative maps search engine)
FOURSQUARE_API_KEY=YOUR_FOURSQUARE_API_KEY_HERE
